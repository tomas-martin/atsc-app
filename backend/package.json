{
  "name": "atsc-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
  "build":  "prisma generate --schema src/prisma/schema.prisma",
  "start":  "node src/index.js",
  "dev":    "nodemon src/index.js",
  "db:migrate": "npx prisma migrate dev --schema src/prisma/schema.prisma",
  "db:seed":    "node seed.js"
},
  "dependencies": {
    "@prisma/client": "^5.11.0",
    "bcryptjs":       "^2.4.3",
    "cors":           "^2.8.5",
    "dotenv":         "^16.4.5",
    "express":        "^4.18.3",
    "jsonwebtoken":   "^9.0.2",
    "morgan":         "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma":  "^5.11.0"
  }
}
