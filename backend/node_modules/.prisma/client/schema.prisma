// Prisma schema para ATSC - Andes Talleres Sporting Club
// Generado a partir del XML de GeneXus

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── USUARIOS ─────────────────────────────────────────────────────────
model Usuario {
  id        Int      @id @default(autoincrement())
  usuario   String   @unique @db.VarChar(30)
  password  String   @db.VarChar(255)
  nombre    String   @db.VarChar(60)
  tipoId    Int
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  tipo TipoPersona @relation(fields: [tipoId], references: [id])
  logs Log[]

  @@map("usuarios")
}

// ── PERSONAS / JUGADORES ─────────────────────────────────────────────
model Persona {
  id         Int       @id @default(autoincrement())
  estado     Boolean   @default(true)
  apellido   String    @db.VarChar(30)
  nombre     String    @db.VarChar(30)
  alias      String?   @db.VarChar(30)
  completo   String?   @db.VarChar(60)
  documento  String?   @db.VarChar(15)
  nroCarnet  String?   @db.VarChar(20)
  carnet     String?   @db.VarChar(30)
  fechaNac   DateTime? @db.Date
  domicilio  String?   @db.VarChar(60)
  localidad  String?   @db.VarChar(30)
  grupo      String?   @db.VarChar(5)
  obraSocial String?   @db.VarChar(30)
  telefono   String?   @db.VarChar(20)
  telefono1  String?   @db.VarChar(20)
  telefono2  String?   @db.VarChar(20)
  foto       String?   @db.VarChar(255)
  mail       String?   @db.VarChar(60)
  mail2      String?   @db.VarChar(60)
  nroSocio   Int?
  asistencia Int?      @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tiposPersona    PersonaTipo[]
  plantelPartidos PlantelPartido[]
  cuotas          Cuota[]
  pases           Pase[]
  asistencias     AsistenciaPersona[]

  @@map("personas")
}

model TipoPersona {
  id     Int    @id @default(autoincrement())
  nombre String @db.VarChar(30)

  personas PersonaTipo[]
  usuarios Usuario[]

  @@map("tipos_persona")
}

model PersonaTipo {
  personaId Int
  tipoId    Int
  persona   Persona     @relation(fields: [personaId], references: [id])
  tipo      TipoPersona @relation(fields: [tipoId], references: [id])

  @@id([personaId, tipoId])
  @@map("personas_tipos")
}

model Puesto {
  id     Int    @id @default(autoincrement())
  nombre String @db.VarChar(30)

  @@map("puestos")
}

// ── TORNEOS Y EQUIPOS ────────────────────────────────────────────────
model Torneo {
  id          Int     @id @default(autoincrement())
  nombre      String  @db.VarChar(60)
  fecha       String? @db.VarChar(20)
  campeon     Int?
  campeon1    Int?
  campeon2    Int?
  categoriaId Int?

  categoria TipoCategoria? @relation(fields: [categoriaId], references: [id])
  partidos  Partido[]
  clubs     TorneoClub[]

  @@map("torneos")
}

model TipoCategoria {
  id     Int    @id @default(autoincrement())
  nombre String @db.VarChar(30)

  torneos    Torneo[]
  categorias Categoria[]

  @@map("tipos_categoria")
}

model Club {
  id        Int     @id @default(autoincrement())
  nombre    String  @db.VarChar(60)
  direccion String? @db.VarChar(100)

  equipos Equipo[]
  torneos TorneoClub[]

  @@map("clubs")
}

model TorneoClub {
  torneoId Int
  clubId   Int
  torneo   Torneo @relation(fields: [torneoId], references: [id])
  club     Club   @relation(fields: [clubId], references: [id])

  @@id([torneoId, clubId])
  @@map("torneos_clubs")
}

model Equipo {
  id         Int    @id @default(autoincrement())
  nombre     String @db.VarChar(60)
  campeonato Int?
  clubId     Int?

  club              Club?     @relation(fields: [clubId], references: [id])
  partidosLocal     Partido[] @relation("LocalEquipo")
  partidosVisitante Partido[] @relation("VisitanteEquipo")

  @@map("equipos")
}

// ── CATEGORÍAS ───────────────────────────────────────────────────────
model Categoria {
  id              Int       @id @default(autoincrement())
  nombre          String    @db.VarChar(60)
  tipoCategoriaId Int?
  clase           String?   @db.VarChar(10)
  hasta           Int?
  estado          Boolean   @default(true)
  fecha           DateTime? @db.Date
  torneoId        Int?
  fefusa          String?   @db.VarChar(20)
  letra           String?   @db.VarChar(5)
  dt              String?   @db.VarChar(60)
  ac              String?   @db.VarChar(60)
  pf              String?   @db.VarChar(60)

  tipoCategoria TipoCategoria? @relation(fields: [tipoCategoriaId], references: [id])

  @@map("categorias")
}

// ── PARTIDOS ─────────────────────────────────────────────────────────
model Partido {
  id             Int      @id @default(autoincrement())
  fecha          DateTime @db.Date
  fechaNro       Int?
  torneoId       Int?
  equipoLocalId  Int?
  golesLocal     Int      @default(0)
  equipoVisId    Int?
  golesVisitante Int      @default(0)
  cerrado        Boolean  @default(false)
  video          String?  @db.VarChar(255)
  foto           String?  @db.VarChar(255)
  createdAt      DateTime @default(now())

  torneo          Torneo?          @relation(fields: [torneoId], references: [id])
  equipoLocal     Equipo?          @relation("LocalEquipo", fields: [equipoLocalId], references: [id])
  equipoVisitante Equipo?          @relation("VisitanteEquipo", fields: [equipoVisId], references: [id])
  plantel         PlantelPartido[]

  @@map("partidos")
}

model PlantelPartido {
  id          Int     @id @default(autoincrement())
  partidoId   Int
  personaId   Int
  alias       String? @db.VarChar(30)
  nroCamiseta Int?
  goles       Int     @default(0)
  amarillas   Int     @default(0)
  azules      Int     @default(0)
  faltas      Int     @default(0)
  suspendido  Boolean @default(false)
  capitan     Boolean @default(false)
  pt_inicio   Int?
  pt_fin      Int?
  st_inicio   Int?
  st_fin      Int?

  partido Partido @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  persona Persona @relation(fields: [personaId], references: [id])

  @@map("plantel_partidos")
}

// ── CUOTAS ───────────────────────────────────────────────────────────
model Cuota {
  id        Int      @id @default(autoincrement())
  personaId Int
  mes       Int
  anio      Int
  fecha     DateTime @db.Date
  monto     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  persona Persona @relation(fields: [personaId], references: [id])

  @@unique([personaId, mes, anio])
  @@map("cuotas")
}

// ── ASISTENCIA ───────────────────────────────────────────────────────
model Asistencia {
  id              Int      @id @default(autoincrement())
  fecha           DateTime @db.Date
  horaInicio      String?  @db.VarChar(8)
  horaFin         String?  @db.VarChar(8)
  tipoCategoriaId Int?
  usuarioId       Int?
  createdAt       DateTime @default(now())

  personas AsistenciaPersona[]

  @@map("asistencias")
}

model AsistenciaPersona {
  asistenciaId Int
  personaId    Int

  asistencia Asistencia @relation(fields: [asistenciaId], references: [id])
  persona    Persona    @relation(fields: [personaId], references: [id])

  @@id([asistenciaId, personaId])
  @@map("asistencias_personas")
}

// ── PASES ────────────────────────────────────────────────────────────
model Pase {
  id          Int      @id @default(autoincrement())
  personaId   Int
  fecha       DateTime @db.Date
  clubOrigen  String?  @db.VarChar(60)
  clubDestino String?  @db.VarChar(60)
  monto       Decimal? @db.Decimal(10, 2)
  observacion String?  @db.Text
  imagen      String?  @db.VarChar(255)
  createdAt   DateTime @default(now())

  persona Persona @relation(fields: [personaId], references: [id])

  @@map("pases")
}

// ── CAMISETAS ────────────────────────────────────────────────────────
model Camiseta {
  id              Int       @id @default(autoincrement())
  nombre          String    @db.VarChar(60)
  detalle         String?   @db.VarChar(100)
  tipoCategoriaId Int?
  responsable     String?   @db.VarChar(60)
  marca           String?   @db.VarChar(30)
  tipo            String?   @db.VarChar(20)
  fecha           DateTime? @db.Date
  cantidad        Int?
  cantPantalon    Int?

  numeros CamisetaNumero[]

  @@map("camisetas")
}

model CamisetaNumero {
  id         Int     @id @default(autoincrement())
  camisetaId Int
  nro        Int?
  pecho      String? @db.VarChar(5)
  pantalon   String? @db.VarChar(5)
  estado     String? @db.VarChar(20)

  camiseta Camiseta @relation(fields: [camisetaId], references: [id], onDelete: Cascade)

  @@map("camisetas_numeros")
}

// ── NOTAS Y MENSAJES ─────────────────────────────────────────────────
model Nota {
  id        Int      @id @default(autoincrement())
  nombre    String   @db.VarChar(60)
  detalle   String?  @db.Text
  fecha     DateTime @db.Date
  imagen    String?  @db.VarChar(255)
  usuarioId Int?
  createdAt DateTime @default(now())

  @@map("notas")
}

model Mensaje {
  id     Int     @id @default(autoincrement())
  linea1 String? @db.VarChar(255)
  linea2 String? @db.VarChar(255)
  linea3 String? @db.VarChar(255)

  @@map("mensajes")
}

// ── LOGS ─────────────────────────────────────────────────────────────
model Log {
  id        Int      @id @default(autoincrement())
  usuarioId Int?
  fecha     DateTime @default(now())
  evento    String   @db.VarChar(255)

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("logs")
}
